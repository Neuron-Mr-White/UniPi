  "dependencies": {
    "@pi-unipi/core": "*"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "*"
  },
  "scripts": {
    "test": "npx tsx --test tests/**/*.test.ts"
  }
}

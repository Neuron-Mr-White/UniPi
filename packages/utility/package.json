{
  "name": "@pi-unipi/utility",
  "version": "0.2.5",
  "description": "Utility commands and tools for Pi coding agent — lifecycle, diagnostics, cache, analytics, display, batch execution",
  "type": "module",
  "license": "MIT",
  "author": "Neuron Mr White",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Neuron-Mr-White/unipi.git",
    "directory": "packages/utility"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-coding-agent",
    "unipi",
    "utility",
    "continue",
    "diagnostics",
    "cache",
    "analytics"
  ],
  "files": [
    "src/index.ts",
    "src/commands.ts",
    "src/types.ts",
    "src/**/*.ts",
    "README.md",
    "skills/**/*.md"
  ],
  "pi": {
    "extensions": [
      "src/index.ts"
    ]
  },
  "publishConfig": {
    "access": "public"
